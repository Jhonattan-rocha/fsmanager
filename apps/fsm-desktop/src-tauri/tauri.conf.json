{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fsm-desktop",
  "version": "0.1.0",
  "identifier": "com.risetec.fsmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "fsm-desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "RiseTec",
    "category": "Utility",
    "licenseFile": "../../../LICENSE",
    "shortDescription": "Gerenciador de container virtual (cofre .vault)",
    "longDescription": "fsmanager — guarda todos os seus arquivos dentro de um único container virtual, com criptografia, deduplicação, compressão, snapshots e montagem como drive.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
